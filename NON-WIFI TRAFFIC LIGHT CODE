// Wemos D1 Mini Traffic Light - Final Version (Red LED Common Anode)

enum State { GREEN, YELLOW, RED };

// Pins for LEDs
const byte LED_RED    = D5;  
const byte LED_YELLOW = D6;
const byte LED_GREEN  = D7;  


unsigned long nowMs, stateStartMs;
State state = GREEN;


// Durations (milliseconds)
const unsigned long T_GREEN  = 5000UL;
const unsigned long T_YELLOW = 2000UL;
const unsigned long T_RED    = 5000UL;


// Function to set LED states
// Red is inverted because it is common anode
void setLights(bool r, bool y, bool g) {
  digitalWrite(LED_RED, r);
  digitalWrite(LED_YELLOW, y);
  digitalWrite(LED_GREEN,  g);
}


// Enter new state
void enter(State s) {
  state = s;
  stateStartMs = millis();


  if (s == GREEN)  setLights(false, false, true);  // Green ON
  if (s == YELLOW) setLights(false, true,  false); // Yellow ON
  if (s == RED)    setLights(true,  false, false); // Red ON (inverted inside setLights)
}


// Setup pins
void setup() {
  pinMode(LED_RED, OUTPUT);
  pinMode(LED_YELLOW, OUTPUT);
  pinMode(LED_GREEN, OUTPUT);


  // Turn off all LEDs initially
  setLights(false, false, false);


  enter(GREEN);  // Start with green
}

// Loop traffic light
void loop() {
  nowMs = millis();
  unsigned long elapsed = nowMs - stateStartMs;


  switch (state) {
    case GREEN:
      if (elapsed >= T_GREEN) enter(YELLOW);
      break;


    case YELLOW:
      if (elapsed >= T_YELLOW) enter(RED);
      break;


    case RED:
      if (elapsed >= T_RED) enter(GREEN);
      break;
  }
}
