#include <ESP8266WiFi.h>

const char* ssid = "wemos-lasalle";
const char* password = "animo";

WiFiServer server(80);

const byte LED_RED    = D5;  
const byte LED_YELLOW = D6;
const byte LED_GREEN  = D7;

String mode = "AUTO";

unsigned long previousMillis = 0;
int autoState = 0;

const unsigned long interval = 2000;

void setLights(bool r, bool y, bool g) {
  digitalWrite(LED_RED, !r); 
  digitalWrite(LED_YELLOW, y);
  digitalWrite(LED_GREEN, g);
}

void handleAuto() {
  unsigned long currentMillis = millis();

  if (currentMillis - previousMillis >= interval) {
    previousMillis = currentMillis;

    if (autoState == 0) {
      setLights(0,0,1); // Green
      autoState = 1;
    }
    else if (autoState == 1) {
      setLights(0,1,0); // Yellow
      autoState = 2;
    }
    else {
      setLights(1,0,0); // Red
      autoState = 0;
    }
  }
}

void setup() {
  Serial.begin(115200);

  pinMode(LED_RED, OUTPUT);
  pinMode(LED_YELLOW, OUTPUT);
  pinMode(LED_GREEN, OUTPUT);

  setLights(0,0,0);

  WiFi.begin(ssid, password);
  Serial.print("Connecting to WiFi");

  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }

  Serial.println("\nConnected!");
  Serial.print("IP Address: ");
  Serial.println(WiFi.localIP());

  server.begin();
}

void loop() {

  if (mode == "AUTO") {
    handleAuto();
  }

  WiFiClient client = server.available();
  if (!client) return;

  String request = client.readStringUntil('\r');
  client.flush();

  if (request.indexOf("/RED") != -1) {
    mode = "MANUAL";
    setLights(1,0,0);
  }

  if (request.indexOf("/YELLOW") != -1) {
    mode = "MANUAL";
    setLights(0,1,0);
  }

  if (request.indexOf("/GREEN") != -1) {
    mode = "MANUAL";
    setLights(0,0,1);
  }

  if (request.indexOf("/AUTO") != -1) {
    mode = "AUTO";
  }

  client.println("HTTP/1.1 200 OK");
  client.println("Content-Type: text/html");
  client.println("");
  client.println("<h1>WiFi Traffic Light</h1>");
  client.println("<a href=\"/RED\"><button style='background:red;width:150px;height:50px;'>RED</button></a><br><br>");
  client.println("<a href=\"/YELLOW\"><button style='background:orange;width:150px;height:50px;'>YELLOW</button></a><br><br>");
  client.println("<a href=\"/GREEN\"><button style='background:green;width:150px;height:50px;'>GREEN</button></a><br><br>");
  client.println("<a href=\"/AUTO\"><button style='width:150px;height:50px;'>AUTO MODE</button></a>");

  client.stop();
}
